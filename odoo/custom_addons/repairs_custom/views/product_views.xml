<odoo>
    <record id="product_template_form_view_inherit_repair" model="ir.ui.view">
        <field name="name">product.template.form.inherit.repair</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="priority">5</field>
        <field name="arch" type="xml">
            <div name="options" position="inside">
                <span class="d-inline-flex" invisible="type == 'combo'">
                    <field name="repair_ok"/>
                    <label for="repair_ok"/>
                </span>
            </div>
        </field>
    </record>

    <record id="view_product_template_search_repair" model="ir.ui.view">
        <field name="name">product.template.search.repair</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_search_view"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='filter_to_purchase']" position="after">
                <filter name="repair_ok" string="Repairable" domain="[('repair_ok','=',True)]"/>
            </xpath>
        </field>
    </record>


</odoo>
