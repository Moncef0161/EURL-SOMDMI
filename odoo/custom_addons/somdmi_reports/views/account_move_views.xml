<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add invoice type field to invoice form view -->
    <record id="view_move_form_invoice_type" model="ir.ui.view">
        <field name="name">account.move.form.invoice.type</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form" />
        <field name="arch" type="xml">
            <!-- Add invoice type field before journal field -->
            <xpath expr="//field[@name='journal_id']" position="before">
                <field name="invoice_type"
                    widget="radio"
                    options="{'horizontal': true}"
                    invisible="move_type not in ('out_invoice', 'out_refund')"
                    required="move_type in ('out_invoice', 'out_refund') and state == 'draft'" />
            </xpath>

            <!-- Make journal_id readonly when invoice_type is set -->
            <xpath expr="//field[@name='journal_id']" position="attributes">
                <attribute name="readonly">invoice_type and state == 'draft'</attribute>
            </xpath>
        </field>
    </record>

    <!-- Add invoice type field to invoice tree view for visibility -->
    <record id="view_invoice_tree_invoice_type" model="ir.ui.view">
        <field name="name">account.move.tree.invoice.type</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_invoice_tree" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="invoice_type" optional="show" />
            </xpath>
        </field>
    </record>

</odoo>