<odoo>
    <data noupdate="1">
        <record id="picking_type_atelier_in" model="stock.picking.type">
            <field name="name">Receipts (Atelier)</field>
            <field name="code">incoming</field>
            <field name="sequence_code">ATEL-IN</field>
            <field name="warehouse_id" ref="stock.warehouse0"/>
            <field name="default_location_src_id" ref="stock.stock_location_customers"/>
            <field name="default_location_dest_id" ref="atelier_repair.stock_location_atelier_customer"/>
            <field name="use_create_lots">True</field>
            <field name="use_existing_lots">False</field>
            <field name="show_operations">True</field>
        </record>

        <record id="picking_type_atelier_out" model="stock.picking.type">
            <field name="name">Delivery Orders (Atelier)</field>
            <field name="code">outgoing</field>
            <field name="sequence_code">ATEL-OUT</field>
            <field name="warehouse_id" ref="stock.warehouse0"/>
            <field name="default_location_src_id" ref="atelier_repair.stock_location_atelier_customer"/>
            <field name="default_location_dest_id" ref="stock.stock_location_customers"/>
            <field name="use_create_lots">False</field>
            <field name="use_existing_lots">True</field>
            <field name="show_operations">True</field>
        </record>
    </data>
</odoo>