<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Actions -->
    <record id="action_product_brand" model="ir.actions.act_window">
        <field name="name">Marques</field>
        <field name="res_model">product.brand</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_product_type" model="ir.actions.act_window">
        <field name="name">Types de Machine</field>
        <field name="res_model">product.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- List Views -->
    <record id="view_product_brand_list" model="ir.ui.view">
        <field name="name">product.brand.list</field>
        <field name="model">product.brand</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="type_id"/>
            </list>
        </field>
    </record>

    <record id="view_product_type_list" model="ir.ui.view">
        <field name="name">product.type.list</field>
        <field name="model">product.type</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>

    <!-- Form Views -->
    <record id="view_product_brand_form" model="ir.ui.view">
        <field name="name">product.brand.form</field>
        <field name="model">product.brand</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="type_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_product_type_form" model="ir.ui.view">
        <field name="name">product.type.form</field>
        <field name="model">product.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Inherit Product Template Form -->
    <record id="inherit_product_template_form" model="ir.ui.view">
        <field name="name">product.template.form.inherit.brand</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='group_general']" position="inside">
                    <field name="type_id" string="Type"/>
                    <field name="brand_id" string="Marque" domain="[('type_id', '=', type_id)]"/>
                    <field name="state" string="État"/>
            </xpath>
        </field>
    </record>
</odoo>