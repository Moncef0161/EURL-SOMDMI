<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_repair_order_form_inherit_breakdown" model="ir.ui.view">
        <field name="name">repair.order.form.inherit.breakdown</field>
        <field name="model">repair.order</field>
        <field name="inherit_id" ref="repair.view_repair_order_form" />
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="%(atelier_repair.action_report_repair_checklist)d"
                    string="Imprimer Fiche de Contrôle"
                    type="action"
                    invisible="machine_type not in ['bout_a_bout', 'electrofusion']" />
            </xpath>
            <xpath expr="//field[@name='product_id']" position="after">
                <field name="machine_type" />
            </xpath>
            <xpath expr="//field[@name='move_ids']/list/field[@name='product_uom']" position="after">
                <field name="price_unit" />
                <field name="tax_id" widget="many2many_tags" />
            </xpath>
            <xpath expr="//page[@name='parts']" position="before">
                <page string="Pannes" name="breakdowns">
                    <group>
                        <field name="declared_breakdown_ids" widget="many2many_tags"
                            options="{'no_create_edit': False}" />
                        <field name="actual_breakdown_ids" widget="many2many_tags"
                            options="{'no_create_edit': False}" />
                    </group>
                </page>
                <page string="Fiche de Contrôle" name="checklist">
                    <!-- Electrofusion Layout (Hardcoded) -->
                    <div invisible="machine_type != 'electrofusion'">
                        <group col="4">
                            <field name="product_id" string="Type" readonly="1" />
                            <field name="ef_serie_no" />
                            <field name="partner_id" string="Client" readonly="1" />
                            <field name="ef_op_no" />
                        </group>
                        <group col="4">
                            <field name="ef_mesure_appareil" />
                            <field name="ef_mesure_serie" />
                            <field name="ef_banc_serie" />
                        </group>

                        <separator string="ETAPES CHRONOLOGIQUES" />
                        <group string="Nettoyage">
                            <field name="ef_row1" widget="radio" options="{'horizontal': true}" />
                        </group>
                        <group string="Contrôles visuels aspect extérieur" col="2">
                            <field name="ef_row2" widget="radio" options="{'horizontal': true}" />
                            <field name="ef_row3" widget="radio" options="{'horizontal': true}" />
                            <field name="ef_row4" widget="radio" options="{'horizontal': true}" />
                            <field name="ef_row5" widget="radio" options="{'horizontal': true}" />
                            <field name="ef_row6" widget="radio" options="{'horizontal': true}" />
                            <field name="ef_row7" widget="radio" options="{'horizontal': true}" />
                            <field name="ef_row8" widget="radio" options="{'horizontal': true}" />
                            <field name="ef_row9" widget="radio" options="{'horizontal': true}" />
                            <field name="ef_row10" widget="radio" options="{'horizontal': true}" />
                            <field name="ef_row11" widget="radio" options="{'horizontal': true}" />
                            <field name="ef_row12" widget="radio" options="{'horizontal': true}" />
                            <field name="ef_row13" widget="radio" options="{'horizontal': true}" />
                            <field name="ef_row14" widget="radio" options="{'horizontal': true}" />
                            <field name="ef_row15" widget="radio" options="{'horizontal': true}" />
                            <field name="ef_row16" widget="radio" options="{'horizontal': true}" />
                            <field name="ef_row17" widget="radio" options="{'horizontal': true}" />
                            <field name="ef_row18" widget="radio" options="{'horizontal': true}" />
                            <field name="ef_row19" widget="radio" options="{'horizontal': true}" />
                            <field name="ef_row20" widget="radio" options="{'horizontal': true}" />
                        </group>
                        <group string="Contrôles sous tension" col="2">
                            <field name="ef_row21" widget="radio" options="{'horizontal': true}" />
                            <field name="ef_row22" widget="radio" options="{'horizontal': true}" />
                            <field name="ef_row23" widget="radio" options="{'horizontal': true}" />
                            <field name="ef_row24" widget="radio" options="{'horizontal': true}" />
                            <field name="ef_row25" widget="radio" options="{'horizontal': true}" />
                        </group>
                        <group string="Contrôles visuels et opérations internes" col="2">
                            <field name="ef_row26" widget="radio" options="{'horizontal': true}" />
                            <field name="ef_row27" widget="radio" options="{'horizontal': true}" />
                            <field name="ef_row28" widget="radio" options="{'horizontal': true}" />
                            <field name="ef_row29" widget="radio" options="{'horizontal': true}" />
                            <field name="ef_row30" widget="radio" options="{'horizontal': true}" />
                            <field name="ef_row31" widget="radio" options="{'horizontal': true}" />
                            <field name="ef_row32" widget="radio" options="{'horizontal': true}" />
                            <field name="ef_row33" widget="radio" options="{'horizontal': true}" />
                        </group>
                        <group string="Contrôle final" col="2">
                            <field name="ef_row34" widget="radio" options="{'horizontal': true}" />
                            <field name="ef_row35" widget="radio" options="{'horizontal': true}" />
                            <field name="ef_row36" widget="radio" options="{'horizontal': true}" />
                        </group>

                        <separator string="Remplacements de Matériel – Evolution du logiciel" />
                        <group col="2">
                            <field name="ef_carte_usb" />
                            <field name="ef_version_logiciel" />
                        </group>

                        <separator string="RELEVE D’ESSAIS FINALS" />
                        <group col="2">
                            <field name="ef_test_1" string="14 V (13,79V ↔ 14,21V) 0,25 Ω" />
                            <field name="ef_test_2" string="24 V (23,64V ↔ 24,36V) 0,25 Ω" />
                            <field name="ef_test_3" string="30 V (29,55V ↔ 30,45V) 0,40 Ω" />
                            <field name="ef_test_4" string="42 V (41,50V ↔ 42,50V) 0,65 Ω" />
                            <field name="ef_test_5" string="35 V (34,50V ↔ 35,50V) 1,00 Ω" />
                            <field name="ef_test_6" string="39 V (38,50V ↔ 39,50V) 2,00 Ω" />
                            <field name="ef_test_7" string="24 V (23,64V ↔ 24,36V) 5,00 Ω" />
                            <field name="ef_test_8" string="30 V (29,55V ↔ 30,45V) 5,00 Ω" />
                            <field name="ef_test_9" string="39 V (38,50V ↔ 39,50V) 10,0 Ω" />
                            <field name="ef_test_10" string="42 V (41,50V ↔ 42,50V) 15,0 Ω" />
                            <field name="ef_test_manuel" string="Mode Manuel : Régulation à ± 1,5%" />
                        </group>

                        <group>
                            <field name="ef_essais_autres" />
                            <field name="ef_observations" />
                        </group>
                    </div>

                    <!-- Bout à Bout Layout (Hardcoded) -->
                    <div invisible="machine_type != 'bout_a_bout'">
                        <group col="4">
                            <field name="bb_serie_no" />
                            <field name="bb_decharge_no" />
                            <field name="partner_id" string="CLIENT" readonly="1" />
                            <field name="bb_date_reparation" />
                        </group>

                        <separator string="Diagnostique de la machine" />
                        <p>Problèmes au niveau de :</p>
                        <group col="6">
                            <field name="bb_diag_alimentation" />
                            <field name="bb_diag_pression" />
                            <field name="bb_diag_deplacement" />
                            <field name="bb_diag_temperature" />
                            <field name="bb_diag_clavier" />
                            <field name="bb_diag_autre" />
                        </group>

                        <separator string="ETAPES CHRONOLOGIQUES" />
                        <group col="2">
                            <field name="bb_chrono_deplacement" widget="radio"
                                options="{'horizontal': true}" />
                            <field name="bb_chrono_pression" widget="radio"
                                options="{'horizontal': true}" />
                            <field name="bb_chrono_element_chauffant" widget="radio"
                                options="{'horizontal': true}" />
                            <field name="bb_chrono_rabot" widget="radio"
                                options="{'horizontal': true}" />
                            <field name="bb_chrono_bati" widget="radio"
                                options="{'horizontal': true}" />
                        </group>

                        <group col="4">
                            <field name="bb_cycle_soudage" />
                            <field name="bb_diam" />
                            <field name="bb_conforme" />
                            <field name="bb_impression_donnees" />
                        </group>
                        <field name="bb_remarque" placeholder="Remarque..." />

                        <separator string="Contrôles du Bâti" />
                        <group col="2">
                            <field name="bb_bati_connexions" />
                            <field name="bb_bati_ecrous" />
                            <field name="bb_bati_surfaces" />
                            <field name="bb_bati_plaque" />
                        </group>

                        <separator string="Contrôles du Rabot" />
                        <group col="2">
                            <field name="bb_rabot_etat" />
                            <field name="bb_rabot_lames" />
                            <field name="bb_rabot_translation" />
                        </group>

                        <separator string="Contrôles de l'Elément Chauffant" />
                        <group col="2">
                            <field name="bb_chauffant_surface" />
                            <field name="bb_chauffant_mecanique" />
                            <field name="bb_chauffant_carter" />
                        </group>

                        <separator string="Contrôles de l'Unité Hydraulique" />
                        <group col="2">
                            <field name="bb_hydraulique_boutons" />
                            <field name="bb_hydraulique_fixation" />
                            <field name="bb_hydraulique_flexibles" />
                            <field name="bb_hydraulique_huile" />
                        </group>

                        <separator string="Contrôles du Moniteur Informatisé" />
                        <group col="2">
                            <field name="bb_moniteur_etat" />
                        </group>

                        <separator string="Contrôles de l'Unité Hydraulique (machine manuelle)" />
                        <group col="2">
                            <field name="bb_manuelle_levier" />
                            <field name="bb_manuelle_regulateur" />
                            <field name="bb_manuelle_bypass" />
                        </group>

                        <separator string="Pressions manomètre de contrôle (Bar)" />
                        <group col="4">
                            <label for="bb_pres_5" string="5 Bar (4,5 - 5,5)" />
                            <field name="bb_pres_5" nolabel="1" />
                            <label for="bb_pres_10" string="10 Bar (9,0 - 11,0)" />
                            <field name="bb_pres_10" nolabel="1" />
                            <label for="bb_pres_15" string="15 Bar (13,5 - 16,5)" />
                            <field name="bb_pres_15" nolabel="1" />
                            <label for="bb_pres_30" string="30 Bar (27,0 - 33,0)" />
                            <field name="bb_pres_30" nolabel="1" />
                            <label for="bb_pres_50" string="50 Bar (46,5 - 53,5)" />
                            <field name="bb_pres_50" nolabel="1" />
                            <label for="bb_pres_75" string="75 Bar (69,75 - 80,25)" />
                            <field name="bb_pres_75" nolabel="1" />
                            <label for="bb_pres_100" string="100 Bar (93,00 - 107,0)" />
                            <field name="bb_pres_100" nolabel="1" />
                        </group>

                        <separator string="Machine Automatique : Contrôle du soudage" />
                        <group col="2">
                            <field name="bb_auto_cycle" />
                            <field name="bb_auto_bourrelet" />
                            <field name="bb_auto_ticket" />
                        </group>

                        <field name="bb_observations" placeholder="Observations / Evolutions..." />
                    </div>
                </page>
                <page string="Documents" name="documents">
                    <group>
                        <group string="Bon de Réception">
                            <field name="reception_no" />
                            <field name="devis_approx" />
                            <button name="action_generate_reception_no"
                                string="Générer N° Réception" type="object" class="btn-secondary"
                                invisible="reception_no" />
                        </group>
                        <group string="Bon de Livraison">
                            <field name="livraison_no" />
                            <field name="mode_paiement" />
                            <field name="timbre" />
                            <field name="etabli_par" />
                            <button name="action_generate_livraison_no"
                                string="Générer N° Livraison" type="object" class="btn-secondary"
                                invisible="livraison_no" />
                        </group>
                    </group>
                    <group class="oe_subtotal_footer oe_right">
                        <field name="amount_untaxed" widget="monetary"
                            options="{'currency_field': 'currency_id'}" />
                        <field name="amount_tax" widget="monetary"
                            options="{'currency_field': 'currency_id'}" />
                        <div class="oe_subtotal_footer_separator oe_inline o_td_label">
                            <label for="amount_total" />
                        </div>
                        <field name="amount_total" nolabel="1" class="oe_subtotal_footer_separator"
                            widget="monetary" options="{'currency_field': 'currency_id'}" />
                        <field name="amount_net_payer" widget="monetary"
                            options="{'currency_field': 'currency_id'}" />
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>