<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_repair_checklist" model="ir.actions.report">
        <field name="name">Fiche de Contrôle</field>
        <field name="model">repair.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">atelier_repair.report_checklist_template</field>
        <field name="report_file">atelier_repair.report_checklist_template</field>
        <field name="print_report_name">'Fiche de Controle - %s' % (object.name)</field>
        <field name="binding_model_id" ref="repair.model_repair_order" />
        <field name="binding_type">report</field>
    </record>

    <template id="report_checklist_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <style>
                            .bb-table { width: 100%; border-collapse: collapse; margin-bottom: 10px;
                            font-size: 12px; }
                            .bb-table th, .bb-table td { border: 1px solid black; padding: 4px; }
                            .bb-header-bg { background-color: yellow; font-weight: bold; text-align:
                            center; }
                            .bb-section-bg { background-color: #e9ecef; font-weight: bold; }
                            .text-center { text-align: center; }
                        </style>

                        <!-- Electrofusion Layout -->
                        <t t-if="o.machine_type == 'electrofusion'">
                            <div class="oe_structure" />
                            <div class="text-center">
                                <h2>FICHE DE CONTROLE ELECTROFUSION</h2>
                            </div>

                            <div class="row mt32 mb32">
                                <div class="col-3">
                                    <strong>Ordre:</strong>
                                    <p t-field="o.name" />
                                </div>
                                <div class="col-3">
                                    <strong>Client:</strong>
                                    <p t-field="o.partner_id" />
                                </div>
                                <div class="col-3">
                                    <strong>Produit:</strong>
                                    <p t-field="o.product_id" />
                                </div>
                                <div class="col-3">
                                    <strong>Date:</strong>
                                    <p t-field="o.create_date" t-options='{"widget": "date"}' />
                                </div>
                            </div>

                            <table class="table table-sm o_main_table mt16">
                                <thead>
                                    <tr>
                                        <th>Section</th>
                                        <th>Opération</th>
                                        <th class="text-center">Conforme</th>
                                        <th class="text-center">N.C</th>
                                        <th class="text-center">Corrigé</th>
                                        <th>Observation</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="o.checklist_ids" t-as="line">
                                        <tr>
                                            <td>
                                                <span t-field="line.name" />
                                            </td>
                                            <td>
                                                <span t-field="line.section" />
                                            </td>
                                            <td class="text-center">
                                                <span t-if="line.is_conforme">X</span>
                                            </td>
                                            <td class="text-center">
                                                <span t-if="line.is_nc">X</span>
                                            </td>
                                            <td class="text-center">
                                                <span t-if="line.is_corrige">X</span>
                                            </td>
                                            <td>
                                                <span t-field="line.observation" />
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>

                        <!-- Bout à Bout Layout (Hardcoded) -->
                        <t t-if="o.machine_type == 'bout_a_bout'">
                            <table class="bb-table">
                                <tr>
                                    <td rowspan="2"
                                        style="width: 30%; text-align: center; vertical-align: middle;">
                                        <img t-if="o.company_id.logo"
                                            t-att-src="image_data_uri(o.company_id.logo)"
                                            style="max-height: 80px;" />
                                    </td>
                                    <td class="bb-header-bg" style="width: 40%; font-size: 16px;">
                                        FICHE DE CONTROLE<br />BOUT A BOUT </td>
                                    <td style="width: 30%;"> Le : <span
                                            t-field="o.bb_date_reparation" /><br /> Type : <span
                                            t-field="o.product_id" /><br /> Par : <span
                                            t-field="o.user_id" />
                                    </td>
                                </tr>
                                <tr>
                                    <td>N° de décharge : <span t-field="o.bb_decharge_no" /></td>
                                    <td>CLIENT : <span t-field="o.partner_id" /></td>
                                </tr>
                                <tr>
                                    <td>Série N° : <span t-field="o.bb_serie_no" /></td>
                                    <td colspan="2"></td>
                                </tr>
                            </table>

                            <div class="row mt16">
                                <div class="col-7">
                                    <h4 style="text-decoration: underline;">Diagnostique de la
                                        machine</h4>
                                    <p>Problèmes au niveau de :</p>
                                </div>
                                <div class="col-5">
                                    <table class="bb-table">
                                        <tr>
                                            <td class="bb-header-bg">Alimentation</td>
                                            <td style="width: 40px;" class="text-center">
                                                <span t-if="o.bb_diag_alimentation">X</span>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="bb-header-bg">Pression</td>
                                            <td class="text-center">
                                                <span t-if="o.bb_diag_pression">X</span>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="bb-header-bg">Déplacent</td>
                                            <td class="text-center">
                                                <span t-if="o.bb_diag_deplacement">X</span>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="bb-header-bg">Température</td>
                                            <td class="text-center">
                                                <span t-if="o.bb_diag_temperature">X</span>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="bb-header-bg">Clavier</td>
                                            <td class="text-center">
                                                <span t-if="o.bb_diag_clavier">X</span>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="bb-header-bg">Autre</td>
                                            <td class="text-center">
                                                <span t-if="o.bb_diag_autre">X</span>
                                            </td>
                                        </tr>
                                    </table>
                                </div>
                            </div>

                            <table class="bb-table mt16">
                                <thead>
                                    <tr class="bb-header-bg">
                                        <th colspan="4">ETAPES CHRONOLOGIQUES</th>
                                    </tr>
                                    <tr>
                                        <th style="width: 40%;"></th>
                                        <th class="text-center">CONFIRME</th>
                                        <th class="text-center">N.C</th>
                                        <th class="text-center">CORRIGE</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>Test de déplacement</td>
                                        <td class="text-center">
                                            <span t-if="o.bb_chrono_deplacement == 'conforme'">X</span>
                                        </td>
                                        <td class="text-center">
                                            <span t-if="o.bb_chrono_deplacement == 'nc'">X</span>
                                        </td>
                                        <td class="text-center">
                                            <span t-if="o.bb_chrono_deplacement == 'corrige'">X</span>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>Test de pression</td>
                                        <td class="text-center">
                                            <span t-if="o.bb_chrono_pression == 'conforme'">X</span>
                                        </td>
                                        <td class="text-center">
                                            <span t-if="o.bb_chrono_pression == 'nc'">X</span>
                                        </td>
                                        <td class="text-center">
                                            <span t-if="o.bb_chrono_pression == 'corrige'">X</span>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>Vérification d'élément chauffant</td>
                                        <td class="text-center">
                                            <span t-if="o.bb_chrono_element_chauffant == 'conforme'">
                                                X</span>
                                        </td>
                                        <td class="text-center">
                                            <span t-if="o.bb_chrono_element_chauffant == 'nc'">X</span>
                                        </td>
                                        <td class="text-center">
                                            <span t-if="o.bb_chrono_element_chauffant == 'corrige'">
                                                X</span>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>Vérification rabot</td>
                                        <td class="text-center">
                                            <span t-if="o.bb_chrono_rabot == 'conforme'">X</span>
                                        </td>
                                        <td class="text-center">
                                            <span t-if="o.bb_chrono_rabot == 'nc'">X</span>
                                        </td>
                                        <td class="text-center">
                                            <span t-if="o.bb_chrono_rabot == 'corrige'">X</span>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>Vérification bâti</td>
                                        <td class="text-center">
                                            <span t-if="o.bb_chrono_bati == 'conforme'">X</span>
                                        </td>
                                        <td class="text-center">
                                            <span t-if="o.bb_chrono_bati == 'nc'">X</span>
                                        </td>
                                        <td class="text-center">
                                            <span t-if="o.bb_chrono_bati == 'corrige'">X</span>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>

                            <div class="row mt16">
                                <div class="col-6"> Cycle de soudage : <span
                                        t-field="o.bb_cycle_soudage" /><br /> Impressionnes données
                                    : <span t-if="o.bb_impression_donnees">X</span><br />Date de
                                    réparation : <span t-field="o.bb_date_reparation" />
                                </div>
                                <div class="col-6"> DIAM : <span t-field="o.bb_diam" /><br />
                                    Conforme : <span t-if="o.bb_conforme">X</span>
                                </div>
                            </div>

                            <table class="bb-table mt16">
                                <tr class="bb-section-bg">
                                    <td>Remarque</td>
                                </tr>
                                <tr>
                                    <td style="height: 60px;">
                                        <span t-field="o.bb_remarque" />
                                    </td>
                                </tr>
                            </table>

                            <div style="page-break-before: always;"></div>

                            <table class="bb-table">
                                <tr class="bb-header-bg">
                                    <td style="width: 70%;">Contrôles du Bâti</td>
                                    <td>Conformité</td>
                                </tr>
                                <tr>
                                    <td>Connexions hydrauliques</td>
                                    <td class="text-center">
                                        <span t-if="o.bb_bati_connexions">X</span>
                                    </td>
                                </tr>
                                <tr>
                                    <td>Etat et fonctionnement libre des écrous de mors</td>
                                    <td class="text-center">
                                        <span t-if="o.bb_bati_ecrous">X</span>
                                    </td>
                                </tr>
                                <tr>
                                    <td>Etat des surfaces bâti – mors – vérins</td>
                                    <td class="text-center">
                                        <span t-if="o.bb_bati_surfaces">X</span>
                                    </td>
                                </tr>
                                <tr>
                                    <td>Plaque signalétique correctement renseignée</td>
                                    <td class="text-center">
                                        <span t-if="o.bb_bati_plaque">X</span>
                                    </td>
                                </tr>

                                <tr class="bb-header-bg">
                                    <td>Contrôles du Rabot</td>
                                    <td>Conformité</td>
                                </tr>
                                <tr>
                                    <td>Etat général</td>
                                    <td class="text-center">
                                        <span t-if="o.bb_rabot_etat">X</span>
                                    </td>
                                </tr>
                                <tr>
                                    <td>Etat des Lames</td>
                                    <td class="text-center">
                                        <span t-if="o.bb_rabot_lames">X</span>
                                    </td>
                                </tr>
                                <tr>
                                    <td>Translation libre</td>
                                    <td class="text-center">
                                        <span t-if="o.bb_rabot_translation">X</span>
                                    </td>
                                </tr>

                                <tr class="bb-header-bg">
                                    <td>Contrôles de l'Elément Chauffant</td>
                                    <td>Conformité</td>
                                </tr>
                                <tr>
                                    <td>Etat Surface &amp; revêtement Téflon</td>
                                    <td class="text-center">
                                        <span t-if="o.bb_chauffant_surface">X</span>
                                    </td>
                                </tr>
                                <tr>
                                    <td>Libre fonctionnement mécanique</td>
                                    <td class="text-center">
                                        <span t-if="o.bb_chauffant_mecanique">X</span>
                                    </td>
                                </tr>
                                <tr>
                                    <td>Etat carter de protection</td>
                                    <td class="text-center">
                                        <span t-if="o.bb_chauffant_carter">X</span>
                                    </td>
                                </tr>

                                <tr class="bb-header-bg">
                                    <td>Contrôles de l'Unité Hydraulique</td>
                                    <td>Conformité</td>
                                </tr>
                                <tr>
                                    <td>Etat des boutons, leviers, mano. (Si manuelle)</td>
                                    <td class="text-center">
                                        <span t-if="o.bb_hydraulique_boutons">X</span>
                                    </td>
                                </tr>
                                <tr>
                                    <td>Fixation des sous ensembles</td>
                                    <td class="text-center">
                                        <span t-if="o.bb_hydraulique_fixation">X</span>
                                    </td>
                                </tr>
                                <tr>
                                    <td>Etat des flexibles et connecteurs rapides</td>
                                    <td class="text-center">
                                        <span t-if="o.bb_hydraulique_flexibles">X</span>
                                    </td>
                                </tr>
                                <tr>
                                    <td>Vérification du niveau d'huile</td>
                                    <td class="text-center">
                                        <span t-if="o.bb_hydraulique_huile">X</span>
                                    </td>
                                </tr>

                                <tr class="bb-header-bg">
                                    <td>Contrôles du Moniteur Informatisé</td>
                                    <td>Conformité</td>
                                </tr>
                                <tr>
                                    <td>Etat général et fixations</td>
                                    <td class="text-center">
                                        <span t-if="o.bb_moniteur_etat">X</span>
                                    </td>
                                </tr>
                            </table>

                            <div style="page-break-before: always;"></div>

                            <table class="bb-table">
                                <tr class="bb-header-bg">
                                    <td style="width: 70%;">Contrôles de l'Unité Hydraulique
                                        (machine manuelle)</td>
                                    <td>Conformité</td>
                                </tr>
                                <tr>
                                    <td>Fonctionnement levier Ouverture / Fermeture</td>
                                    <td class="text-center">
                                        <span t-if="o.bb_manuelle_levier">X</span>
                                    </td>
                                </tr>
                                <tr>
                                    <td>Fonctionnement régulateur pression</td>
                                    <td class="text-center">
                                        <span t-if="o.bb_manuelle_regulateur">X</span>
                                    </td>
                                </tr>
                                <tr>
                                    <td>Fonctionnement du "By Pass"</td>
                                    <td class="text-center">
                                        <span t-if="o.bb_manuelle_bypass">X</span>
                                    </td>
                                </tr>
                            </table>

                            <table class="bb-table mt16">
                                <thead>
                                    <tr>
                                        <th style="width: 30%;">Pressions de machine (Bar)</th>
                                        <th colspan="3" class="text-center">Pressions manomètre de
                                            contrôle (Bar)</th>
                                    </tr>
                                    <tr>
                                        <th></th>
                                        <th class="text-center">min</th>
                                        <th class="text-center">Réelle</th>
                                        <th class="text-center">max</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>5</td>
                                        <td class="text-center">4,5</td>
                                        <td class="text-center">
                                            <span t-field="o.bb_pres_5" />
                                        </td>
                                        <td class="text-center">5,5</td>
                                    </tr>
                                    <tr>
                                        <td>10</td>
                                        <td class="text-center">9,0</td>
                                        <td class="text-center">
                                            <span t-field="o.bb_pres_10" />
                                        </td>
                                        <td class="text-center">11,0</td>
                                    </tr>
                                    <tr>
                                        <td>15</td>
                                        <td class="text-center">13,5</td>
                                        <td class="text-center">
                                            <span t-field="o.bb_pres_15" />
                                        </td>
                                        <td class="text-center">16,5</td>
                                    </tr>
                                    <tr>
                                        <td>30</td>
                                        <td class="text-center">27,0</td>
                                        <td class="text-center">
                                            <span t-field="o.bb_pres_30" />
                                        </td>
                                        <td class="text-center">33,0</td>
                                    </tr>
                                    <tr>
                                        <td>50</td>
                                        <td class="text-center">46,5</td>
                                        <td class="text-center">
                                            <span t-field="o.bb_pres_50" />
                                        </td>
                                        <td class="text-center">53,5</td>
                                    </tr>
                                    <tr>
                                        <td>75</td>
                                        <td class="text-center">69,75</td>
                                        <td class="text-center">
                                            <span t-field="o.bb_pres_75" />
                                        </td>
                                        <td class="text-center">80,25</td>
                                    </tr>
                                    <tr>
                                        <td>100</td>
                                        <td class="text-center">93,00</td>
                                        <td class="text-center">
                                            <span t-field="o.bb_pres_100" />
                                        </td>
                                        <td class="text-center">107,0</td>
                                    </tr>
                                </tbody>
                            </table>

                            <table class="bb-table mt16">
                                <tr class="bb-header-bg">
                                    <td style="width: 70%;">Machine Automatique : Contrôle du
                                        soudage</td>
                                    <td>Conformité</td>
                                </tr>
                                <tr>
                                    <td>DEROULEMENT DU CYCLE</td>
                                    <td class="text-center">
                                        <span t-if="o.bb_auto_cycle">X</span>
                                    </td>
                                </tr>
                                <tr>
                                    <td>ASPECT BOURRELET</td>
                                    <td class="text-center">
                                        <span t-if="o.bb_auto_bourrelet">X</span>
                                    </td>
                                </tr>
                                <tr>
                                    <td>EDITION DU TICKET DE CYCLE</td>
                                    <td class="text-center">
                                        <span t-if="o.bb_auto_ticket">X</span>
                                    </td>
                                </tr>
                            </table>

                            <table class="bb-table mt16">
                                <tr class="bb-section-bg">
                                    <td>Observations / Evolutions :</td>
                                </tr>
                                <tr>
                                    <td style="height: 100px;">
                                        <span t-field="o.bb_observations" />
                                    </td>
                                </tr>
                            </table>
                        </t>
                        <div class="oe_structure" />
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>