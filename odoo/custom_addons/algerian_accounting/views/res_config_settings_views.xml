<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.invoice.error.margin</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@name='fiscal_localization_setting_container']" position="after">
                <block title="Error Margin" name="error_margin_setting_container">
                    <setting id="invoice_error_margin_setting" help="Global error margin for invoices.">
                        <field name="invoice_error_margin"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>