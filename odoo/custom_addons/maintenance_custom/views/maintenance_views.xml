<odoo>
    <record id="equipment_request_view_form_custom" model="ir.ui.view">
        <field name="name">equipment.request.form.custom</field>
        <field name="model">maintenance.request</field>
        <field name="inherit_id" ref="maintenance.hr_equipment_request_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='owner_user_id']" position="replace">
                <field name="owner_partner_id" string="Owner"/>
            </xpath>
        </field>
    </record>

    <record id="hr_equipment_view_form_custom" model="ir.ui.view">
        <field name="name">equipment.form.custom</field>
        <field name="model">maintenance.equipment</field>
        <field name="inherit_id" ref="maintenance.hr_equipment_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='owner_user_id']" position="replace">
                <field name="owner_partner_id" string="Owner"/>
            </xpath>
        </field>
    </record>

